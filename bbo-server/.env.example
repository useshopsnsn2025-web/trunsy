APP_DEBUG = false

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = 127.0.0.1
DATABASE = bbo
USERNAME = your_db_user
PASSWORD = your_db_password
HOSTPORT = 3306
CHARSET = utf8mb4
DEBUG = false
PREFIX =

[LANG]
default_lang = en-us

[JWT]
SECRET = your-random-jwt-secret-key-64-chars
TTL = 7200
REFRESH_TTL = 604800

[R2]
ENABLED = false

[GOOGLE]
CLIENT_ID =
CLIENT_SECRET =
